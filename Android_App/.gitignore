# IDE
.idea/
*.iml
*.iws
*.ipr

# 本地配置
local.properties

# 操作系统
.DS_Store
Thumbs.db

# 编译产物
app/build/
*/build/
*.apk
*.aab
*.dex
*.class

# 日志
*.log

# 临时文件
*.tmp
*.swp
*.bak
*~
