<!--
============================================================================
文件名: fragment_debug.xml
功能描述:
  - 调试页面布局（开发者模式激活后可见）
  - 原始传感器数据显示区
  - 图像预览区（UDP 接收的 JPEG）
  - TFLite 识别结果显示区
  - 避障分析结果显示区
  - 网络统计信息区
  - 日志显示区（带滚动和清空按钮）
依赖关系:
  - 被 DebugFragment 加载
  - 视图 ID 与 DebugFragment.java 中 findViewById 对应
============================================================================
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- 页面标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="调试面板"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#D32F2F"
            android:gravity="center"
            android:paddingTop="12dp"
            android:paddingBottom="16dp" />

        <!-- ==================== 原始传感器数据 ==================== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="原始传感器数据"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1565C0"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/text_raw_sensor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="等待数据..."
                    android:textSize="14sp"
                    android:textColor="#424242"
                    android:fontFamily="monospace" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ==================== 图像预览 ==================== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="图像预览（UDP 接收）"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1565C0"
                    android:paddingBottom="8dp" />

                <ImageView
                    android:id="@+id/image_preview"
                    android:layout_width="match_parent"
                    android:layout_height="240dp"
                    android:background="#000000"
                    android:scaleType="fitCenter"
                    android:contentDescription="接收到的图像" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ==================== 视觉识别结果 ==================== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="TFLite 识别结果"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1565C0"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/text_classify_result"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="等待识别..."
                    android:textSize="14sp"
                    android:textColor="#424242"
                    android:fontFamily="monospace" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ==================== 避障分析结果 ==================== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="避障分析结果"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1565C0"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/text_analysis_result"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="等待分析..."
                    android:textSize="14sp"
                    android:textColor="#424242"
                    android:fontFamily="monospace" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ==================== 网络统计 ==================== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="网络统计"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1565C0"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/text_network_stats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="等待统计..."
                    android:textSize="14sp"
                    android:textColor="#424242"
                    android:fontFamily="monospace" />

                <Button
                    android:id="@+id/btn_reset_stats"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="8dp"
                    android:text="重置统计"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#FF9800" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ==================== 日志显示 ==================== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="运行日志"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#1565C0" />

                    <Button
                        android:id="@+id/btn_clear_log"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="清空"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#D32F2F" />

                </LinearLayout>

                <ScrollView
                    android:id="@+id/scroll_log"
                    android:layout_width="match_parent"
                    android:layout_height="300dp">

                    <TextView
                        android:id="@+id/text_log"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="日志区域...\n"
                        android:textSize="12sp"
                        android:textColor="#424242"
                        android:fontFamily="monospace"
                        android:background="#F5F5F5"
                        android:padding="8dp" />

                </ScrollView>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
