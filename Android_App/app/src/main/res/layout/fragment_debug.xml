<!--
============================================================================
文件名: fragment_debug.xml
功能描述: 开发者调试面板布局 v3.0
  - HC-SR04超声波雷达可视化 (类雷达扇形显示)
  - SDM10激光测距数字显示
  - AI检测框叠加预览 + 原图直出预览 (双屏)
  - 处理后的传感器/视觉数据
  - 网络状态统计
  - 运行日志
依赖关系:
  - 被 DebugFragment 加载
  - RadarView 是自定义 View (com.smarteye.blindguide.ui.RadarView)
  - DetectionOverlayView 是自定义 View
  - 视图 ID 与 DebugFragment.java 中 findViewById 对应
============================================================================
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- 页面标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔧 开发者调试面板 v3.0"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FF9800"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="12dp" />

        <!-- ==================== HC-SR04 超声波雷达可视化 ==================== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#16213E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📡 HC-SR04 超声波雷达"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#00E5FF" />

                    <Button
                        android:id="@+id/btn_http_camera"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="HTTP直连"
                        android:textSize="11sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#1565C0"
                        android:minWidth="0dp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp" />
                </LinearLayout>

                <com.smarteye.blindguide.ui.RadarView
                    android:id="@+id/radar_view"
                    android:layout_width="match_parent"
                    android:layout_height="280dp"
                    android:contentDescription="HC-SR04超声波雷达可视化" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ==================== AI检测框叠加预览 ==================== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#16213E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🤖 AI视觉处理 (检测框叠加)"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#4FC3F7" />

                    <TextView
                        android:id="@+id/text_frame_info"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="等待视频..."
                        android:textSize="12sp"
                        android:textColor="#90A4AE" />
                </LinearLayout>

                <com.smarteye.blindguide.ui.DetectionOverlayView
                    android:id="@+id/detection_overlay"
                    android:layout_width="match_parent"
                    android:layout_height="240dp"
                    android:background="#000000"
                    android:contentDescription="AI检测框叠加视频" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ==================== 原始视频直出 ==================== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#16213E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🖼️ 原图直出 (原始画面)"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#66BB6A" />

                    <TextView
                        android:id="@+id/text_raw_video_info"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="等待..."
                        android:textSize="12sp"
                        android:textColor="#90A4AE" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/image_raw_video"
                    android:layout_width="match_parent"
                    android:layout_height="240dp"
                    android:background="#000000"
                    android:scaleType="fitCenter"
                    android:contentDescription="原始JPEG视频直出" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ==================== 传感器数据(激光+超声波+camera_ip) ==================== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#16213E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📡 传感器数据 (SDM10 + HC-SR04)"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#4CAF50"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/text_laser_dist"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔴 SDM10激光: --"
                    android:textSize="15sp"
                    android:textColor="#B0BEC5"
                    android:fontFamily="monospace"
                    android:paddingBottom="4dp" />

                <TextView
                    android:id="@+id/text_ultrasonic_dist"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔵 HC-SR04超声波: --"
                    android:textSize="15sp"
                    android:textColor="#B0BEC5"
                    android:fontFamily="monospace"
                    android:paddingBottom="4dp" />

                <TextView
                    android:id="@+id/text_camera_ip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📷 摄像板IP: --"
                    android:textSize="15sp"
                    android:textColor="#81D4FA"
                    android:fontFamily="monospace"
                    android:paddingBottom="2dp" />

                <TextView
                    android:id="@+id/text_raw_timestamp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="时间戳: --"
                    android:textSize="13sp"
                    android:textColor="#78909C"
                    android:fontFamily="monospace" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ==================== 处理后数据 ==================== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#16213E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚙️ 处理与决策"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FF9800"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/text_danger_level"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="危险等级: --"
                    android:textSize="13sp"
                    android:textColor="#B0BEC5"
                    android:fontFamily="monospace"
                    android:paddingBottom="2dp" />

                <TextView
                    android:id="@+id/text_min_distance"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="最近距离: --"
                    android:textSize="13sp"
                    android:textColor="#B0BEC5"
                    android:fontFamily="monospace"
                    android:paddingBottom="2dp" />

                <TextView
                    android:id="@+id/text_debounce_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="防抖状态: --"
                    android:textSize="13sp"
                    android:textColor="#90A4AE"
                    android:fontFamily="monospace"
                    android:paddingBottom="2dp" />

                <TextView
                    android:id="@+id/text_advice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="避障建议: --"
                    android:textSize="13sp"
                    android:textColor="#B0BEC5"
                    android:fontFamily="monospace"
                    android:paddingBottom="2dp" />

                <TextView
                    android:id="@+id/text_detection_count"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="视觉检测: --"
                    android:textSize="13sp"
                    android:textColor="#81D4FA"
                    android:fontFamily="monospace" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ==================== 网络统计 ==================== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#16213E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🌐 网络状态"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#CE93D8"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/text_network_stats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="等待连接..."
                    android:textSize="13sp"
                    android:textColor="#B0BEC5"
                    android:fontFamily="monospace" />

                <Button
                    android:id="@+id/btn_reset_stats"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="8dp"
                    android:text="重置统计"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#7B1FA2" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ==================== 日志 ==================== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#16213E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📋 运行日志"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#EF5350" />

                    <Button
                        android:id="@+id/btn_clear_log"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:text="清空"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#D32F2F" />

                </LinearLayout>

                <ScrollView
                    android:id="@+id/scroll_log"
                    android:layout_width="match_parent"
                    android:layout_height="280dp"
                    android:background="#0D1117">

                    <TextView
                        android:id="@+id/text_log"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="日志区域...\n"
                        android:textSize="11sp"
                        android:textColor="#8B949E"
                        android:fontFamily="monospace"
                        android:padding="8dp" />

                </ScrollView>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
